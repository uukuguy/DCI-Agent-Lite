# Copy this file to .env only for provider-backed Asterion DCI operations.
# Provider-free discovery, tests, builds, and acceptance need no credentials.

# External Pi checkout and generated outputs, relative to the project root.
DCI_PI_DIR=./pi
DCI_PI_AGENT_DIR=~/.pi/agent
ASTERION_DCI_PI_DIR=
ASTERION_DCI_OUTPUT_ROOT=./outputs/asterion-dci-runs

# Parent directory containing externally supplied wiki_corpus and bc_plus_docs.
ASTERION_DCI_CORPUS_ROOT=./corpus
# Optional launcher root containing external data/ and corpus/ trees.
# The standalone project root is the default external resource parent.
ASTERION_DCI_RESOURCE_ROOT=.
ASTERION_RUNTIME_CWD=.

# Agent runtime selection. These are the effective Pi runtime defaults.
DCI_RUNTIME=pi
DCI_PROVIDER=openai-codex
DCI_MODEL=gpt-5.6-luna
DCI_RUNTIME_CONTEXT_LEVEL=level3
DCI_RPC_TIMEOUT_SECONDS=3600

# Provider credentials remain in their provider-specific variables.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_CN_API_KEY=

# Judge defaults match JudgeConfig; only the named credential remains empty.
DCI_EVAL_JUDGE_BASE_URL=https://api.deepseek.com/v1
DCI_EVAL_JUDGE_API=chat-completions
DCI_EVAL_JUDGE_MODEL=deepseek-v4-flash
DCI_EVAL_JUDGE_API_KEY_ENV=DEEPSEEK_API_KEY
DCI_EVAL_JUDGE_TIMEOUT_SECONDS=120
DCI_EVAL_JUDGE_THINKING=disabled
DCI_EVAL_JUDGE_JSON_MODE=true
DCI_EVAL_JUDGE_STRICT_JSON_SCHEMA=false
DCI_EVAL_JUDGE_RESPONSES_STORE=false
DCI_EVAL_JUDGE_MAX_OUTPUT_TOKENS=1024
DCI_EVAL_JUDGE_INPUT_PRICE_PER_1M=0
DCI_EVAL_JUDGE_CACHED_INPUT_PRICE_PER_1M=0
DCI_EVAL_JUDGE_OUTPUT_PRICE_PER_1M=0
# DEEPSEEK_API_KEY=
