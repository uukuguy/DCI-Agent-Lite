# Copy this file to .env only for provider-backed Asterion DCI operations.
# Provider-free discovery, tests, builds, and acceptance need no credentials.

# External Pi checkout and generated outputs, relative to the project root.
DCI_PI_DIR=./pi
ASTERION_DCI_PI_DIR=
ASTERION_DCI_OUTPUT_ROOT=./outputs/asterion-dci-runs

# Parent directory containing externally supplied wiki_corpus and bc_plus_docs.
ASTERION_DCI_CORPUS_ROOT=./corpus
ASTERION_RUNTIME_CWD=.

# Agent runtime selection. Leave provider/model empty until intentionally used.
DCI_RUNTIME=pi
DCI_PROVIDER=
DCI_MODEL=
DCI_RUNTIME_CONTEXT_LEVEL=level3
DCI_RPC_TIMEOUT_SECONDS=3600

# Provider credentials remain in their provider-specific variables.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MINIMAX_API_KEY=
# MINIMAX_CN_API_KEY=

# Judge selection. The named secret variable remains empty and uncommitted.
DCI_EVAL_JUDGE_MODEL=deepseek-v4-flash
DCI_EVAL_JUDGE_API_KEY_ENV=DEEPSEEK_API_KEY
# DEEPSEEK_API_KEY=

