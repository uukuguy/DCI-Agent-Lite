{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dci.reproduction-run-manifest/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "product",
    "profile_id",
    "profile_identity_sha256",
    "runtime_id",
    "effective_config_identity_sha256",
    "paper_benchmark_inventory_sha256",
    "paper_experiment_scopes_sha256",
    "scope_ids",
    "queries",
    "aggregates",
    "identity_sha256"
  ],
  "properties": {
    "schema": {"const": "dci.reproduction-run-manifest/v1"},
    "product": {"enum": ["original-dci", "asterion-dci"]},
    "profile_id": {"type": "string", "minLength": 1},
    "profile_identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "runtime_id": {"enum": ["pi", "claude-code"]},
    "effective_config_identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "paper_benchmark_inventory_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "paper_experiment_scopes_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scope_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/query"}
    },
    "aggregates": {"$ref": "#/$defs/aggregates"},
    "identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "query_id",
        "dataset_id",
        "scope_id",
        "status",
        "judge_verdict",
        "ndcg_at_10",
        "evidence_sha256",
        "failure_class",
        "exclusion_reason",
        "agent_operations",
        "judge_operations",
        "input_tokens",
        "output_tokens",
        "cost_usd"
      ],
      "properties": {
        "schema": {"const": "dci.reproduction-query-evidence/v1"},
        "query_id": {"type": "string", "minLength": 1},
        "dataset_id": {"type": "string", "minLength": 1},
        "scope_id": {"type": "string", "minLength": 1},
        "status": {"enum": ["completed", "failed", "cancelled", "timed_out", "missing"]},
        "judge_verdict": {"type": ["boolean", "null"]},
        "ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "evidence_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "failure_class": {"type": ["string", "null"], "minLength": 1},
        "exclusion_reason": {"type": ["string", "null"], "minLength": 1},
        "agent_operations": {"type": "integer", "minimum": 0},
        "judge_operations": {"type": "integer", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "aggregates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "query_count",
        "completed_count",
        "failure_count",
        "excluded_count",
        "accuracy",
        "mean_ndcg_at_10",
        "agent_operations",
        "judge_operations",
        "input_tokens",
        "output_tokens",
        "cost_usd"
      ],
      "properties": {
        "query_count": {"type": "integer", "minimum": 1},
        "completed_count": {"type": "integer", "minimum": 0},
        "failure_count": {"type": "integer", "minimum": 0},
        "excluded_count": {"type": "integer", "minimum": 0},
        "accuracy": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "mean_ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "agent_operations": {"type": "integer", "minimum": 0},
        "judge_operations": {"type": "integer", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0}
      }
    }
  }
}
