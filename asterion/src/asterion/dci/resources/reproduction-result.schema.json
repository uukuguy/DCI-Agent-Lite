{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dci.reproduction-results/v1",
  "oneOf": [
    {"$ref": "#/$defs/run_manifest"},
    {"$ref": "#/$defs/comparison_report"}
  ],
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema": {}, "run_id": {}, "product": {}, "implementation_sha256": {},
    "profile_id": {}, "profile_sha256": {}, "profile_provider": {}, "profile_model": {},
    "runtime": {}, "dataset_id": {}, "selection_id": {}, "selection_sha256": {},
    "effective_config_sha256": {}, "product_effective_config_sha256": {},
    "metric_contract_sha256": {}, "metric_identities": {}, "queries": {},
    "aggregates": {}, "comparison_kind": {}, "baseline_run_sha256": {},
    "candidate_run_sha256": {}, "target_identity": {}, "target_sha256": {},
    "target_sample_ids": {}, "target_samples": {}, "pair_ids": {},
    "exclusion_ids": {}, "baseline": {}, "candidate": {}, "metrics": {},
    "pairs": {}, "exclusions": {}, "baseline_product": {},
    "baseline_implementation_sha256": {},
    "baseline_product_effective_config_sha256": {}, "candidate_product": {},
    "candidate_implementation_sha256": {},
    "candidate_product_effective_config_sha256": {},
    "accepted": {}, "identity_sha256": {}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "public_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/+@-]*$"},
    "versioned_reason": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*/v[1-9][0-9]*$"},
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "judge"],
      "properties": {
        "agent": {"type": "integer", "minimum": 0},
        "judge": {"type": "integer", "minimum": 0}
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "cached_input", "output"],
      "properties": {
        "input": {"type": "integer", "minimum": 0},
        "cached_input": {"type": "integer", "minimum": 0},
        "output": {"type": "integer", "minimum": 0}
      }
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query_id", "status", "judge_verdict", "ndcg_at_10", "failure_class", "exclusion_reason", "evidence_sha256", "operations", "tokens", "cost_usd"],
      "properties": {
        "query_id": {"$ref": "#/$defs/public_id"},
        "status": {"enum": ["completed", "failed", "cancelled", "timed_out", "missing"]},
        "judge_verdict": {"type": ["boolean", "null"]},
        "ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "failure_class": {"oneOf": [{"$ref": "#/$defs/versioned_reason"}, {"type": "null"}]},
        "exclusion_reason": {"oneOf": [{"$ref": "#/$defs/versioned_reason"}, {"type": "null"}]},
        "evidence_sha256": {"$ref": "#/$defs/sha256"},
        "operations": {"$ref": "#/$defs/operations"},
        "tokens": {"$ref": "#/$defs/tokens"},
        "cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "aggregates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query_count", "included_count", "excluded_count", "completed_count", "failed_count", "cancelled_count", "timed_out_count", "missing_count", "accuracy", "mean_ndcg_at_10", "agent_operations", "judge_operations", "input_tokens", "cached_input_tokens", "output_tokens", "total_tokens", "cost_usd"],
      "properties": {
        "query_count": {"type": "integer", "minimum": 1},
        "included_count": {"type": "integer", "minimum": 0},
        "excluded_count": {"type": "integer", "minimum": 0},
        "completed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "cancelled_count": {"type": "integer", "minimum": 0},
        "timed_out_count": {"type": "integer", "minimum": 0},
        "missing_count": {"type": "integer", "minimum": 0},
        "accuracy": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "mean_ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "agent_operations": {"type": "integer", "minimum": 0},
        "judge_operations": {"type": "integer", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "run_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "run_id", "product", "implementation_sha256", "profile_id", "profile_sha256", "runtime", "dataset_id", "selection_id", "selection_sha256", "effective_config_sha256", "product_effective_config_sha256", "metric_contract_sha256", "metric_identities", "queries", "aggregates", "identity_sha256"],
      "properties": {
        "schema": {"const": "dci.reproduction-run/v1"},
        "run_id": {"$ref": "#/$defs/public_id"},
        "product": {"enum": ["original-dci", "asterion-dci"]},
        "implementation_sha256": {"$ref": "#/$defs/sha256"},
        "profile_id": {"$ref": "#/$defs/public_id"},
        "profile_sha256": {"$ref": "#/$defs/sha256"},
        "runtime": {"enum": ["pi", "claude-code"]},
        "dataset_id": {"$ref": "#/$defs/public_id"},
        "selection_id": {"$ref": "#/$defs/public_id"},
        "selection_sha256": {"$ref": "#/$defs/sha256"},
        "effective_config_sha256": {"$ref": "#/$defs/sha256"},
        "product_effective_config_sha256": {"$ref": "#/$defs/sha256"},
        "metric_contract_sha256": {"$ref": "#/$defs/sha256"},
        "metric_identities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/public_id"}},
        "queries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/query"}},
        "aggregates": {"$ref": "#/$defs/aggregates"},
        "identity_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "comparison_totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completion_rate", "failure_rate", "agent_operations", "judge_operations", "input_tokens", "cached_input_tokens", "output_tokens", "total_tokens", "cost_usd"],
      "properties": {
        "completion_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "failure_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "agent_operations": {"type": "integer", "minimum": 0},
        "judge_operations": {"type": "integer", "minimum": 0},
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "confidence_interval": {
      "type": "object", "additionalProperties": false,
      "required": ["lower", "upper"],
      "properties": {"lower": {"type": "number"}, "upper": {"type": "number"}}
    },
    "estimator": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "seed", "resamples", "sample_sha256"],
      "properties": {
        "name": {"enum": ["paired-bootstrap-percentile/v1", "one-sample-bootstrap-percentile/v1"]},
        "seed": {"type": "integer"},
        "resamples": {"const": 10000},
        "sample_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "metric_comparison": {
      "type": "object", "additionalProperties": false,
      "required": ["baseline", "candidate", "delta", "confidence_interval", "margin", "accepted", "estimator"],
      "properties": {
        "baseline": {"type": "number"}, "candidate": {"type": "number"},
        "delta": {"type": "number"}, "confidence_interval": {"$ref": "#/$defs/confidence_interval"},
        "margin": {"type": "number"}, "accepted": {"type": "boolean"},
        "estimator": {"$ref": "#/$defs/estimator"}
      }
    },
    "comparison_metrics": {
      "type": "object", "additionalProperties": false,
      "properties": {
        "accuracy": {"$ref": "#/$defs/metric_comparison"},
        "ndcg_at_10": {"$ref": "#/$defs/metric_comparison"}
      }
    },
    "compared_query": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "judge_verdict", "ndcg_at_10", "evidence_sha256"],
      "properties": {
        "status": {"enum": ["completed", "failed", "cancelled", "timed_out", "missing"]},
        "judge_verdict": {"type": ["boolean", "null"]},
        "ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "evidence_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "excluded_query": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "judge_verdict", "ndcg_at_10", "evidence_sha256", "exclusion_reason"],
      "properties": {
        "status": {"enum": ["completed", "failed", "cancelled", "timed_out", "missing"]},
        "judge_verdict": {"type": ["boolean", "null"]},
        "ndcg_at_10": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "evidence_sha256": {"$ref": "#/$defs/sha256"},
        "exclusion_reason": {"$ref": "#/$defs/versioned_reason"}
      }
    },
    "matched_pair": {
      "type": "object", "additionalProperties": false,
      "required": ["query_id", "baseline", "candidate"],
      "properties": {
        "query_id": {"$ref": "#/$defs/public_id"},
        "baseline": {"$ref": "#/$defs/compared_query"},
        "candidate": {"$ref": "#/$defs/compared_query"}
      }
    },
    "target_sample": {
      "type": "object", "additionalProperties": false,
      "required": ["query_id", "candidate"],
      "properties": {
        "query_id": {"$ref": "#/$defs/public_id"},
        "candidate": {"$ref": "#/$defs/compared_query"}
      }
    },
    "exclusion": {
      "type": "object", "additionalProperties": false,
      "required": ["query_id", "baseline", "candidate"],
      "properties": {
        "query_id": {"$ref": "#/$defs/public_id"},
        "baseline": {"$ref": "#/$defs/excluded_query"},
        "candidate": {"$ref": "#/$defs/excluded_query"}
      }
    },
    "comparison_report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "comparison_kind", "profile_id", "profile_sha256", "profile_provider", "profile_model", "runtime", "dataset_id", "selection_id", "selection_sha256", "effective_config_sha256", "metric_contract_sha256", "metric_identities", "baseline_product", "baseline_implementation_sha256", "baseline_product_effective_config_sha256", "candidate_product", "candidate_implementation_sha256", "candidate_product_effective_config_sha256", "baseline_run_sha256", "candidate_run_sha256", "target_identity", "target_sha256", "target_sample_ids", "target_samples", "pair_ids", "exclusion_ids", "pairs", "exclusions", "baseline", "candidate", "metrics", "accepted", "identity_sha256"],
      "properties": {
        "schema": {"const": "dci.reproduction-comparison/v1"},
        "comparison_kind": {"enum": ["source-parity", "target-comparison"]},
        "profile_id": {"$ref": "#/$defs/public_id"},
        "profile_sha256": {"$ref": "#/$defs/sha256"},
        "profile_provider": {"type": ["string", "null"]},
        "profile_model": {"type": ["string", "null"]},
        "runtime": {"enum": ["pi", "claude-code"]},
        "dataset_id": {"$ref": "#/$defs/public_id"},
        "selection_id": {"$ref": "#/$defs/public_id"},
        "selection_sha256": {"$ref": "#/$defs/sha256"},
        "effective_config_sha256": {"$ref": "#/$defs/sha256"},
        "metric_contract_sha256": {"$ref": "#/$defs/sha256"},
        "metric_identities": {"type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true, "items": {"enum": ["llm-answer-correctness", "ndcg@10-binary-deduplicated"]}},
        "baseline_product": {"type": ["string", "null"], "enum": ["original-dci", null]},
        "baseline_implementation_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "baseline_product_effective_config_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "candidate_product": {"const": "asterion-dci"},
        "candidate_implementation_sha256": {"$ref": "#/$defs/sha256"},
        "candidate_product_effective_config_sha256": {"$ref": "#/$defs/sha256"},
        "baseline_run_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "candidate_run_sha256": {"$ref": "#/$defs/sha256"},
        "target_identity": {"type": ["string", "null"]},
        "target_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "target_sample_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/public_id"}},
        "target_samples": {"type": "array", "items": {"$ref": "#/$defs/target_sample"}},
        "pair_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/public_id"}},
        "exclusion_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/public_id"}},
        "pairs": {"type": "array", "items": {"$ref": "#/$defs/matched_pair"}},
        "exclusions": {"type": "array", "items": {"$ref": "#/$defs/exclusion"}},
        "baseline": {"oneOf": [{"$ref": "#/$defs/comparison_totals"}, {"type": "null"}]},
        "candidate": {"$ref": "#/$defs/comparison_totals"},
        "metrics": {"$ref": "#/$defs/comparison_metrics"},
        "accepted": {"type": ["boolean", "null"]},
        "identity_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  }
}
