{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dci.gold-document-manifest/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "dataset_id", "query_id", "documents"],
  "properties": {
    "schema": {"const": "dci.gold-document-manifest/v1"},
    "dataset_id": {"type": "string", "minLength": 1},
    "query_id": {"type": "string", "minLength": 1},
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "sha256", "evidence_spans"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "evidence_spans": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["start", "end"],
              "properties": {
                "start": {"type": "integer", "minimum": 0},
                "end": {"type": "integer", "minimum": 1}
              }
            }
          }
        }
      }
    }
  }
}
