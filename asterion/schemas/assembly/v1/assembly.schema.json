{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dci.local/schemas/assembly/v1/assembly.schema.json",
  "title": "DCI Static Application Assembly v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol", "application_id", "version", "runtime_id", "packages",
    "host_capabilities", "host_policies", "host_events", "host_artifacts"
  ],
  "properties": {
    "protocol": {"const": "dci.assembly/v1"},
    "application_id": {"$ref": "#/$defs/identifier"},
    "version": {"$ref": "#/$defs/version"},
    "runtime_id": {"$ref": "#/$defs/identifier"},
    "packages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package_id", "version"],
        "properties": {
          "package_id": {"$ref": "#/$defs/identifier"},
          "version": {"$ref": "#/$defs/version"}
        }
      }
    },
    "host_capabilities": {"$ref": "#/$defs/edges"},
    "host_policies": {"$ref": "#/$defs/edges"},
    "host_events": {"$ref": "#/$defs/edges"},
    "host_artifacts": {"$ref": "#/$defs/edges"}
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"},
    "edges": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
