# DCI-Agent-Lite Environment Variables
# Copy this file to .env and fill in your values.

# --- External Pi checkout ---
# New checkouts use ./pi. If unset, DCI auto-detects ./pi first and falls back
# to the legacy ./pi-mono path, so the compatibility symlink is not required.
DCI_PI_DIR=./pi
# --- Independent Asterion DCI product ---
# `asterion-dci` reads only this namespace; it never falls back to DCI_*.
# Leave values empty to use ./pi, ./pi/packages/coding-agent, ./pi/.pi/agent,
# and ./outputs/asterion-dci-runs respectively.
ASTERION_DCI_PI_DIR=
ASTERION_DCI_PI_PACKAGE_DIR=
ASTERION_DCI_PI_AGENT_DIR=
ASTERION_DCI_OUTPUT_ROOT=
# Working corpus/directory used by the installed Asterion Pi runtime.
ASTERION_RUNTIME_CWD=.
# Optional executable for the installed `claude-code.reference` runtime.
# Factory construction only validates this executable; it never authenticates or sends a prompt.
# ASTERION_CLAUDE_EXECUTABLE=claude
# Required together only for `asterion run --provider controlled-code`.
# ASTERION_EXECUTOR_BINARY=/absolute/path/to/dci-controlled-executor
# ASTERION_EXECUTOR_POLICY=/absolute/path/to/executor-policy.json
# ASTERION_EXECUTOR_VALIDATION_CONFIG=/absolute/path/to/validation-config.json
DCI_PI_REPO_URL=https://github.com/earendil-works/pi.git
# By default setup reads the verified full commit from ./pi-revision.txt.
# Override only for a deliberate fork/revision test; prefer a full commit SHA.
# DCI_PI_REVISION=0123456789abcdef0123456789abcdef01234567
# DCI_PI_PACKAGE_DIR=./pi/packages/coding-agent
# DCI_PI_AGENT_DIR=./pi/.pi/agent

# --- Agent model used by scripts/examples/dci_runtime_context_example.sh ---
# These names must match a provider/model available to Pi.
DCI_PROVIDER=anthropic
DCI_MODEL=claude-sonnet-4-20250514

# Wall-clock limit for one programmatic Pi RPC prompt. This includes model,
# tool, retry, and compaction time. Set to 0 only when no deadline is desired.
DCI_RPC_TIMEOUT_SECONDS=3600

# --- Agent and judge API keys (fill in the ones you use) ---
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here

# --- Claude Code runtime (optional alternative to interactive login) ---
# The framework passes the complete caller environment to Claude Code so its
# supported Anthropic-compatible gateways and cloud-provider modes keep working.
# Keep credentials in .env or the process environment; they are not CLI flags or
# Agent Runtime Protocol fields.
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-gateway.example
# ANTHROPIC_AUTH_TOKEN=your_gateway_token_here
# ANTHROPIC_MODEL=your_gateway_model_name

# --- Eval judge: DeepSeek OpenAI-compatible backend (primary example) ---
# dci-agent-lite loads these values automatically when --eval-answer or
# --eval-answer-file is used. The API key is read indirectly so it is not
# duplicated and is never written to evaluation artifacts.
# Run `make check-judge` before a costly batch to make one configured request;
# it reads this key indirectly and never prints or writes the key.
# An already exported process environment value intentionally wins over `.env`.
# The preflight reports judge_api_key_source and a safe shadowing warning.
# Run `make check-judge-config` to inspect them without an HTTP request.
# Base URLs must be absolute HTTP(S) origins and may not include credentials,
# query data, or fragments. Judge redirects are rejected rather than followed.
DCI_EVAL_JUDGE_BASE_URL=https://api.deepseek.com/v1
DCI_EVAL_JUDGE_API=chat-completions
DCI_EVAL_JUDGE_MODEL=deepseek-v4-flash
DCI_EVAL_JUDGE_API_KEY_ENV=DEEPSEEK_API_KEY
DCI_EVAL_JUDGE_TIMEOUT_SECONDS=120
# DeepSeek V4 enables thinking by default. Judging is simple structured output,
# so disable thinking and leave enough room for a complete JSON object.
DCI_EVAL_JUDGE_THINKING=disabled
DCI_EVAL_JUDGE_JSON_MODE=true
# Enable only for a Responses backend that supports strict JSON Schema output.
DCI_EVAL_JUDGE_STRICT_JSON_SCHEMA=false
DCI_EVAL_JUDGE_MAX_OUTPUT_TOKENS=1024

# Set prices for the selected backend if cost estimates are needed. Zero keeps
# local/custom judge runs from being reported with the built-in OpenAI prices.
DCI_EVAL_JUDGE_INPUT_PRICE_PER_1M=0
DCI_EVAL_JUDGE_CACHED_INPUT_PRICE_PER_1M=0
DCI_EVAL_JUDGE_OUTPUT_PRICE_PER_1M=0

# --- Alternative: official OpenAI Responses API ---
# DCI_EVAL_JUDGE_BASE_URL=https://api.openai.com/v1
# DCI_EVAL_JUDGE_API=responses
# DCI_EVAL_JUDGE_MODEL=gpt-5.4-nano
# DCI_EVAL_JUDGE_API_KEY_ENV=OPENAI_API_KEY
# DCI_EVAL_JUDGE_MAX_OUTPUT_TOKENS=1024
# Official Responses requests set `store=false` by default. Set true only when
# you deliberately need OpenAI to retain the response; compatible endpoints omit it.
# DCI_EVAL_JUDGE_RESPONSES_STORE=false

# --- vLLM or another local OpenAI-compatible judge (optional) ---
# VLLM_API_KEY=dummy
# DCI_EVAL_JUDGE_BASE_URL=http://127.0.0.1:8000/v1
# DCI_EVAL_JUDGE_API=chat-completions
# DCI_EVAL_JUDGE_MODEL=Qwen/Qwen3-32B
# DCI_EVAL_JUDGE_API_KEY_ENV=VLLM_API_KEY
# Set JSON_MODE=false only if the compatible backend does not implement
# Chat Completions response_format={"type":"json_object"}.
# DCI_EVAL_JUDGE_JSON_MODE=true
# DCI_EVAL_JUDGE_THINKING=omit

# --- Pi auth directory (optional, if using local Pi auth instead of API keys) ---
# PI_CODING_AGENT_DIR=./pi/.pi/agent

# --- Custom log/analysis paths (optional) ---
# HRCI_ANALYSIS_BASE=/absolute/path/to/log-repo
