{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dci.local/schemas/agent-runtime/v1/runtime-manifest.schema.json",
  "title": "DCI Agent Runtime Protocol v1 Runtime Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "runtime_id", "capabilities"],
  "properties": {
    "protocol": {"const": "dci.agent-runtime/v1"},
    "runtime_id": {"type": "string", "minLength": 1},
    "capabilities": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
