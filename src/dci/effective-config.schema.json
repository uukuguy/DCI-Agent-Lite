{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dci.effective-config/v1",
  "type": "object",
  "required": [
    "schema",
    "product",
    "runtime",
    "agent",
    "context",
    "judge",
    "experiment",
    "sources",
    "identity_sha256"
  ],
  "properties": {
    "schema": {"const": "dci.effective-config/v1"},
    "product": {"const": "original-dci"},
    "runtime": {"const": "pi"},
    "agent": {
      "type": "object",
      "required": ["provider", "model", "reasoning", "tools", "max_turns", "timeout_seconds"],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "reasoning": {"type": ["string", "null"]},
        "tools": {"type": "string", "minLength": 1},
        "max_turns": {"type": "integer", "minimum": 1},
        "timeout_seconds": {"type": ["number", "null"], "exclusiveMinimum": 0}
      },
      "additionalProperties": false
    },
    "context": {"type": "object"},
    "judge": {"type": "object"},
    "experiment": {"type": "object"},
    "sources": {
      "type": "object",
      "additionalProperties": {"enum": ["invocation", "environment", "runtime-default"]}
    },
    "identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "additionalProperties": false
}
